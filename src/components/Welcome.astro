---
import coatOfArms from '../assets/DORION-COA.png';
---

<div id="page">
	<div class="glow glow-red"></div>
	<div class="glow glow-gold"></div>

	<main>
		<section class="hero">
			<div class="copy">
				<p class="eyebrow">Dorion.eth · Powered by ENS + IPFS</p>

				<h1>The first step toward a decentralized cloud.</h1>

				<p class="lead">
					Yeti Grid is an initiative by
					<a href="https://yetistudio.ca">Yeti Digital Studio</a>
					to make websites, APIs, and cloud services portable across decentralized
					infrastructure.
				</p>

				<div class="cards">
					<div class="card">
						<span>01</span>
						<strong>ENS identity</strong>
						<p>Dorion.eth points to content and services using Ethereum Name Service records.</p>
					</div>

					<div class="card">
						<span>02</span>
						<strong>IPFS websites</strong>
						<p>The static site is published to IPFS and served through the Yeti Grid gateway.</p>
					</div>

					<div class="card">
						<span>03</span>
						<strong>Container compute</strong>
						<p>Backend services can run as containers and be routed through the grid.</p>
					</div>
				</div>

				<div class="actions">
					<a class="button primary" href="https://yetistudio.ca">Visit Yeti Digital Studio</a>
					<a class="button secondary" href="https://dorion.yetistudio.ca">dorion.yetistudio.ca</a>
				</div>
			</div>

			<div class="crest-panel">
				<div class="crest-card">
					<img src={coatOfArms.src} alt="Dorion coat of arms" />
				</div>

				<div class="badge">
					<span>ENS</span>
					<strong>Dorion.eth</strong>
				</div>
			</div>
		</section>
	</main>
</div>

<style>
	:global(html) {
		min-height: 100%;
		background: #08080a;
	}

	:global(body) {
		margin: 0;
		min-height: 100%;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		background:
			radial-gradient(circle at 20% 20%, rgba(190, 20, 20, 0.18), transparent 32rem),
			radial-gradient(circle at 80% 10%, rgba(200, 137, 42, 0.18), transparent 28rem),
			linear-gradient(135deg, #07070a 0%, #151014 45%, #0a0a0d 100%);
		color: #fff;
	}

	#page {
		position: relative;
		min-height: 100vh;
		overflow: hidden;
	}

	#page::before {
		content: '';
		position: fixed;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
		background-size: 48px 48px;
		mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.8), transparent);
		pointer-events: none;
	}

	.glow {
		position: absolute;
		width: 24rem;
		height: 24rem;
		border-radius: 999px;
		filter: blur(70px);
		opacity: 0.25;
		pointer-events: none;
	}

	.glow-red {
		top: 8%;
		left: -8rem;
		background: #d71920;
	}

	.glow-gold {
		right: -8rem;
		bottom: 10%;
		background: #c8892a;
	}

	main {
		position: relative;
		z-index: 1;
		min-height: 100vh;
		display: grid;
		place-items: center;
		padding: 48px 24px;
		box-sizing: border-box;
	}

	.hero {
		width: min(1180px, 100%);
		display: grid;
		grid-template-columns: 1.05fr 0.95fr;
		align-items: center;
		gap: 48px;
	}

	.eyebrow {
		display: inline-flex;
		width: fit-content;
		margin: 0 0 18px;
		padding: 8px 12px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.06);
		color: #f3d6d6;
		font-size: 14px;
		letter-spacing: 0.04em;
	}

	h1 {
		margin: 0;
		max-width: 780px;
		font-size: clamp(48px, 8vw, 96px);
		line-height: 0.92;
		letter-spacing: -0.08em;
	}

	.lead {
		max-width: 680px;
		margin: 28px 0 0;
		color: rgba(255, 255, 255, 0.74);
		font-size: clamp(18px, 2vw, 22px);
		line-height: 1.55;
	}

	a {
		color: #ffd28a;
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		margin-top: 34px;
	}

	.card {
		padding: 18px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.065);
		backdrop-filter: blur(18px);
		box-shadow: 0 20px 80px rgba(0, 0, 0, 0.25);
	}

	.card span {
		display: block;
		margin-bottom: 18px;
		color: #c8892a;
		font-size: 13px;
		font-weight: 800;
		letter-spacing: 0.1em;
	}

	.card strong {
		display: block;
		margin-bottom: 8px;
		font-size: 16px;
	}

	.card p {
		margin: 0;
		color: rgba(255, 255, 255, 0.62);
		font-size: 14px;
		line-height: 1.5;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 0 18px;
		border-radius: 999px;
		font-weight: 800;
		text-decoration: none;
	}

	.button:hover {
		text-decoration: none;
	}

	.primary {
		background: #fff;
		color: #100f12;
		box-shadow: 0 16px 40px rgba(255, 255, 255, 0.16);
	}

	.secondary {
		border: 1px solid rgba(255, 255, 255, 0.18);
		background: rgba(255, 255, 255, 0.06);
		color: #fff;
	}

	.crest-panel {
		position: relative;
		display: grid;
		place-items: center;
	}

	.crest-card {
		width: min(540px, 100%);
		padding: 28px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 38px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.9)),
			radial-gradient(circle at 50% 0%, rgba(215, 25, 32, 0.12), transparent 55%);
		box-shadow:
			0 40px 120px rgba(0, 0, 0, 0.55),
			inset 0 0 0 1px rgba(255, 255, 255, 0.5);
		transform: rotate(1.5deg);
	}

	.crest-card img {
		display: block;
		width: 100%;
		height: auto;
		object-fit: contain;
	}

	.badge {
		position: absolute;
		right: 2%;
		bottom: 6%;
		padding: 14px 16px;
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-radius: 18px;
		background: rgba(10, 10, 13, 0.76);
		backdrop-filter: blur(18px);
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.36);
	}

	.badge span {
		display: block;
		color: #c8892a;
		font-size: 12px;
		font-weight: 900;
		letter-spacing: 0.16em;
	}

	.badge strong {
		display: block;
		margin-top: 4px;
		font-size: 18px;
	}

	@media (max-width: 980px) {
		.hero {
			grid-template-columns: 1fr;
		}

		.crest-panel {
			order: -1;
		}

		.crest-card {
			width: min(420px, 100%);
		}

		.cards {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 560px) {
		main {
			padding: 28px 16px;
		}

		.hero {
			gap: 32px;
		}

		h1 {
			font-size: clamp(42px, 15vw, 68px);
		}

		.crest-card {
			padding: 16px;
			border-radius: 28px;
		}

		.badge {
			position: static;
			margin-top: -24px;
			justify-self: end;
		}
	}
</style>